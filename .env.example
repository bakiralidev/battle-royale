# Battle Royale - Environment Variables Example
# Ushbu fayldan nusxa olib, nomini ".env" ga o'zgartiring va o'zingizga mos qiymatlarni kiriting.

# Server ishga tushadigan port
PORT=3000

# JSON Web Token uchun maxfiy kalit (xavfsizlik uchun qiyin kod ishlating)
# JWT_SECRET=super_secret_key_12345

# Ma'lumotlar bazasi fayli manzili
# DB_PATH=backend/battle_royale.db
